{
  "name": "neurophic",
  "version": "0.1.0",
  "description": "TypeScript client for the Neurophic API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neurophic/neurophic-sdk-js.git",
    "directory": "packages/neurophic"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "neurophic",
    "memory",
    "ai",
    "sdk"
  ]
}
