{
  "name": "@neurophic/ai-sdk",
  "version": "0.1.0",
  "description": "Vercel AI SDK tools for Neurophic memory",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "ai": ">=6.0.0",
    "neurophic": "workspace:^",
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "ai": "^6.0.149",
    "neurophic": "workspace:^",
    "tsdown": "^0.21.0",
    "typescript": "^5.5.0",
    "zod": "^4.3.6"
  },
  "license": "MIT",
  "repository": "github:neurophic/neurophic-sdk-js",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "neurophic",
    "memory",
    "ai",
    "vercel",
    "ai-sdk",
    "tools"
  ]
}
